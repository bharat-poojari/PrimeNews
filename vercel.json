{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "vite",
  "outputDirectory": "dist",
  "functions": {
    "api/news.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/news",
      "destination": "/api/news.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/news.js"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "env": {
    "VITE_NEWS_API_KEY": "@news_api_key",
    "VITE_GNEWS_API_KEY": "@gnews_api_key",
    "VITE_MEDIASTACK_API_KEY": "@mediastack_api_key"
  }
}